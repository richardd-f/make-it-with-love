generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// USER & SUBSCRIPTION DOMAIN
// -----------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
  TEACHER
}

model User {
  userId    String   @id @default(uuid()) @map("user_id")
  name      String   @db.VarChar(255)
  address   String?
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @map("created_at")

  // Teacher profile fields (null for USER/ADMIN)
  bio       String?
  photo     String?
  expertise String?
  phone     String?

  // Relations
  subscriptions      UserSubscription[]
  transactions       Transaction[]
  userVideos         UserVideo[]
  carts              Cart[]
  wishlists          Wishlist[]
  enrollments        Enrollment[]
  accounts           Account[]
  sessions           Session[]
  userActions        UserAction[]
  teacherEnrollments TeacherEnrollment[]
  teacherSchedules   TeacherSchedule[]

  @@map("users")
}

model Subscription {
  subscriptionId   String  @id @default(uuid()) @map("subscription_id")
  planName         String  @map("plan_name")
  description      String?
  price            Float
  duration         Int
  meetingAdditions Int     @map("meeting_additions")

  userSubscriptions UserSubscription[]

  @@map("subscriptions")
}

model UserSubscription {
  id                   String   @id @default(uuid()) @map("users_subscriptions")
  userId               String   @map("user_id")
  subscriptionId       String   @map("subscription_id")
  startDate            DateTime @map("start_date")
  status               String
  meetingAdditionsLeft Int      @map("meeting_additions_left")
  coursesClaimedLeft   Int      @default(3) @map("courses_claimed_left")

  user         User         @relation(fields: [userId], references: [userId])
  subscription Subscription @relation(fields: [subscriptionId], references: [subscriptionId])

  @@map("users_subscriptions")
}

// -----------------------------------------------------------------------------
// TRANSACTION DOMAIN
// -----------------------------------------------------------------------------

model Transaction {
  transactionId   String   @id @default(uuid()) @map("transaction_id")
  userId          String   @map("user_id")
  paymentStatus   String   @map("payment_status")
  transactionDate DateTime @map("transaction_date")
  type            String   @default("subscription")

  user               User                @relation(fields: [userId], references: [userId])
  transactionDetails TransactionDetail[]

  @@map("transactions")
}

model TransactionDetail {
  transactionDetailsId String  @id @default(uuid()) @map("transaction_details_id")
  transactionId        String  @map("transaction_id")
  courseId             String? @map("course_id")
  item                 String
  quantity             Int
  totalPrice           Float   @map("total_price")

  transaction Transaction @relation(fields: [transactionId], references: [transactionId])

  @@map("transaction_details")
}

// -----------------------------------------------------------------------------
// COURSE & VIDEO DOMAIN
// -----------------------------------------------------------------------------

model Video {
  id          String  @id @default(uuid())
  title       String
  description String?
  url         String
  courseId    String  @map("course_id")

  course     Course      @relation(fields: [courseId], references: [id])
  userVideos UserVideo[]

  @@map("videos")
}

model UserVideo {
  userVideoId String  @id @default(uuid()) @map("user_video_id")
  userId      String  @map("user_id")
  videoId     String  @map("video_id")
  isDone      Boolean @default(false)

  user  User  @relation(fields: [userId], references: [userId])
  video Video @relation(fields: [videoId], references: [id])

  @@map("user_video")
}

model Course {
  id              String   @id @default(uuid())
  name            String
  description     String?
  imgUrl          String?  @map("img_url")
  minAge          Int      @map("min_age")
  price           Float
  amountOfMeeting Int      @map("amount_of_meeting")
  createdAt       DateTime @default(now()) @map("created_at")

  videos             Video[]
  courseCategories   CourseCategory[]
  courseKits         CourseKit[]
  carts              Cart[]
  wishlists          Wishlist[]
  enrollments        Enrollment[]
  teacherEnrollments TeacherEnrollment[]
  teacherSchedules   TeacherSchedule[]

  @@map("courses")
}

model Category {
  id       String @id @default(uuid())
  category String

  courseCategories CourseCategory[]

  @@map("categories")
}

model CourseCategory {
  id         String @id @default(uuid())
  courseId   String @map("course_id")
  categoryId String @map("category_id")

  course   Course   @relation(fields: [courseId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@map("course_category")
}

// -----------------------------------------------------------------------------
// SHOPPING & KITS DOMAIN
// -----------------------------------------------------------------------------

model DiyKit {
  id          String  @id @default(uuid())
  name        String
  description String?
  price       Float
  stock       Int

  courseKits CourseKit[]

  @@map("diy_kits")
}

model CourseKit {
  id        String @id @default(uuid())
  diyKitsId String @map("diy_kits_id")
  courseId  String @map("course_id")

  diyKit DiyKit @relation(fields: [diyKitsId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@map("course_kits")
}

model Cart {
  cartId    String   @id @default(uuid()) @map("cart_id")
  userId    String   @map("user_id")
  courseId  String   @map("course_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [userId])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@map("carts")
}

model Wishlist {
  wishlistId String   @id @default(uuid()) @map("wishlist_id")
  userId     String   @map("user_id")
  courseId   String   @map("course_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [userId])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@map("wishlists")
}

// -----------------------------------------------------------------------------
// ENROLLMENT & TEACHER DOMAIN
// -----------------------------------------------------------------------------

model Enrollment {
  id                 String @id @default(uuid())
  userId             String @map("user_id")
  courseId           String @map("course_id")
  meetingsAmountLeft Int    @map("meetings_amount_left")

  user           User           @relation(fields: [userId], references: [userId])
  course         Course         @relation(fields: [courseId], references: [id])
  imageGalleries ImageGallery[]
  meetings       Meeting[]

  @@unique([userId, courseId])
  @@map("enrollment")
}

model ImageGallery {
  id           String  @id @default(uuid())
  title        String?
  caption      String?
  url          String
  enrollmentId String  @map("enrollment_id")

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])

  @@map("image_gallery")
}

enum TeacherEnrollmentStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model TeacherEnrollment {
  id        String                  @id @default(uuid())
  teacherId String                  @map("teacher_id")
  courseId  String                  @map("course_id")
  status    TeacherEnrollmentStatus @default(PENDING)
  createdAt DateTime                @default(now()) @map("created_at")

  teacher User   @relation(fields: [teacherId], references: [userId])
  course  Course @relation(fields: [courseId], references: [id])

  @@unique([teacherId, courseId])
  @@map("teacher_enrollment")
}

enum TeacherScheduleStatus {
  AVAILABLE
  BOOKED
}

model TeacherSchedule {
  id         String                @id @default(uuid())
  teacherId  String                @map("teacher_id")
  courseId   String                @map("course_id")
  startTime  DateTime              @map("start_time")
  endTime    DateTime              @map("end_time")
  meetingUrl String                @map("meeting_url")
  status     TeacherScheduleStatus @default(AVAILABLE)
  createdAt  DateTime              @default(now()) @map("created_at")

  teacher  User      @relation(fields: [teacherId], references: [userId])
  course   Course    @relation(fields: [courseId], references: [id])
  meetings Meeting[]

  @@map("teacher_schedule")
}

model Meeting {
  id                String   @id @default(uuid())
  enrollmentId      String   @map("enrollment_id")
  teacherScheduleId String   @map("teacher_schedule_id")
  bookedAt          DateTime @default(now()) @map("booked_at")

  enrollment      Enrollment      @relation(fields: [enrollmentId], references: [id])
  teacherSchedule TeacherSchedule @relation(fields: [teacherScheduleId], references: [id])

  @@map("meeting")
}

// -----------------------------------------------------------------------------
// AUTH DOMAIN
// -----------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("sessions")
}

// -----------------------------------------------------------------------------
// TRACKING DOMAIN (MVP)
// -----------------------------------------------------------------------------

model UserAction {
  id        String   @id @default(uuid())
  action    String
  details   String?
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [userId], onDelete: SetNull)

  @@map("user_actions")
}
